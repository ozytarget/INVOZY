# ═══════════════════════════════════════════════════
# INVOZY V1 — Variables de entorno
# Estas variables se configuran en Railway → Settings → Variables
# Este archivo es SOLO referencia para developers
# ═══════════════════════════════════════════════════

# Database (PostgreSQL — Railway lo provee automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Gemini AI (Work Orders + AI Suggestions)
GEMINI_API_KEY=your-gemini-api-key

# Email service (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@mail.yourdomain.com

# App URL (para share links públicos y emails)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
